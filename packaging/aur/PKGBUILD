pkgname=vaultship-bin
pkgver=0.1.0
pkgrel=1
pkgdesc="Encrypt, harden, bind, and sign container artifacts"
arch=('x86_64' 'aarch64')
url="https://github.com/cyberxdefend/vaultship"
license=('Apache')
provides=('vaultship')
conflicts=('vaultship')
source_x86_64=("vaultship-v${pkgver}-x86_64-unknown-linux-gnu.tar.gz::https://github.com/cyberxdefend/vaultship/releases/download/v${pkgver}/vaultship-v${pkgver}-x86_64-unknown-linux-gnu.tar.gz")
source_aarch64=("vaultship-v${pkgver}-aarch64-unknown-linux-gnu.tar.gz::https://github.com/cyberxdefend/vaultship/releases/download/v${pkgver}/vaultship-v${pkgver}-aarch64-unknown-linux-gnu.tar.gz")
sha256sums_x86_64=('SHA256_X86_64_PLACEHOLDER')
sha256sums_aarch64=('SHA256_AARCH64_PLACEHOLDER')

package() {
  install -Dm755 "${srcdir}/vaultship" "${pkgdir}/usr/bin/vaultship"
}
